{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".env",
      ".env.*",
      "firebase-*.rules",
      "firebase-database.rules.json",
      "node_modules/**",
      "package*.json",
      "server.js",
      "scripts/**",
      "utils/**",
      "supabase-storage-policies.sql",
      "SUPABASE_SETUP.md",
      "telegram-bot-setup.md"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|svg|ico|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/post/**",
        "destination": "/job-detail.html"
      }
    ]
  },
  "database": {
    "rules": "firebase-database.rules.json"
  },
  "storage": {
    "rules": "firebase-storage.rules"
  }
}
