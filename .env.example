FIREBASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app
PORT=3000
ADMIN_EMAIL=admin@example.com
AUTO_JOB_CHECKER_INTERVAL_MS=7200000
CRON_SECRET=change_this_secret_for_external_cron

# Required for admin member create/delete/password APIs.
# Create a Firebase service account JSON, then put its base64 value here.
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_service_account_json

# Optional, only if Supabase upload helpers are used.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
