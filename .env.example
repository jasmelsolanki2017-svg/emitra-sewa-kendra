FIREBASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app
PORT=3000
ADMIN_EMAIL=admin@example.com
AUTO_JOB_CHECKER_INTERVAL_MS=3600000
AUTO_BACKUP_INTERVAL_MS=86400000
CRON_SECRET=change_this_secret_for_external_cron
SITE_BASE_URL=https://emitrawala.online
WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/your_channel_id

# Required for admin member create/delete/password APIs.
# Create a Firebase service account JSON, then put its base64 value here.
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_service_account_json

# Optional, only if Supabase upload helpers are used.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Optional: AI notification summary.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=your_openai_model

# Optional: Telegram auto send.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_or_channel_id

# Optional: WhatsApp Cloud API auto send.
# Direct WhatsApp channel posting is not available from browser JS.
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_TO_NUMBER=919999999999
